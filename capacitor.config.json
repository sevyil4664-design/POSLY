{
  "appId": "com.posly.ios",
  "appName": "Posly",
  "webDir": "www",
  "server": {
    "allowNavigation": ["cloudposly.com", "*.cloudposly.com"],
    "cleartext": false
  },
  "ios": {
    "allowsLinkPreview": false,
    "backgroundColor": "#0a0a0f",
    "preferredContentMode": "mobile",
    "scheme": "posly"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 2000,
      "backgroundColor": "#0a0a0f",
      "showSpinner": false
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#0a0a0f"
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    }
  }
}
