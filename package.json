{
  "name": "posly-ios",
  "version": "1.0.0",
  "description": "Posly Restoran Yönetim - iOS Mobil Uygulama",
  "main": "index.html",
  "scripts": {
    "start": "npx serve www -l 8100",
    "build": "echo 'Static app - no build step needed'",
